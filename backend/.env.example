# ========================================================
# Kowope Foods — Environment Variables
# ========================================================
# Copy this file to .env and fill in your Supabase values
# NEVER commit your real .env to Git!

# --------------------------------------------------------
# DATABASE — Supabase PostgreSQL
# --------------------------------------------------------
# Get this from: Supabase Dashboard → Settings → Database → Connection String → URI
# Replace [YOUR-PASSWORD] with your database password
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# --------------------------------------------------------
# JWT SECRET — Used by FastAPI to sign admin tokens
# --------------------------------------------------------
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-your-own-secret-key-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --------------------------------------------------------
# SUPABASE (for direct SDK use or Storage uploads)
# --------------------------------------------------------
# Get from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# --------------------------------------------------------
# STRIPE (for payment processing)
# --------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --------------------------------------------------------
# FRONTEND URL (for CORS) S9GvL2BR2Lw9B?W
# --------------------------------------------------------
FRONTEND_URL=http://localhost:5173
